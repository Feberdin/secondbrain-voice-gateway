# Purpose: Example environment configuration for the Alexa-compatible OAuth2 server.
# Input/Output: Copy to `.env` and adapt values before starting Docker Compose.
# Invariants: HTTPS is required in production, redirect URIs must match Alexa exactly, and secrets must be replaced.
# Debugging: If Alexa reports account-linking errors, compare your live values with this file and the Docker logs.

NODE_ENV=production
PORT=3000
PUBLIC_BASE_URL=https://secondbrain-voice.feberdin.de
TRUST_PROXY=true
REQUIRE_HTTPS=true

DATABASE_URL=postgres://oauth_user:change_me_db_password@postgres:5432/secondbrain_oauth

CLIENT_ID=alexa-secondbrain
CLIENT_SECRET=replace_with_a_strong_client_secret
DEFAULT_SCOPE=secondbrain.voice
ALLOWED_REDIRECT_URIS=https://alexa.amazon.co.jp/api/skill/link/M28MIEWY5KGX14,https://layla.amazon.com/api/skill/link/M28MIEWY5KGX14,https://pitangui.amazon.com/api/skill/link/M28MIEWY5KGX14

JWT_SECRET=replace_with_a_long_random_jwt_secret
JWT_ISSUER=secondbrain-voice
JWT_AUDIENCE=secondbrain-voice
ACCESS_TOKEN_TTL_SECONDS=3600
REFRESH_TOKEN_TTL_SECONDS=2592000
AUTH_CODE_TTL_SECONDS=300
BCRYPT_ROUNDS=12

# Optional bootstrap admin. Remove after first deployment if you prefer manual user creation.
BOOTSTRAP_USER_EMAIL=admin@example.com
BOOTSTRAP_USER_PASSWORD=change_me_admin_password

