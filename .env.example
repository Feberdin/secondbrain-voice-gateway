# Purpose: Example runtime configuration for local development and Docker deployment.
# Input/Output: Copy this file to `.env` and adapt the values to your environment.
# Invariants: You can use direct env vars or mounted secret files; direct env vars take precedence.
# Debugging: Compare this file with `/debug/snapshot` if the running config looks different than expected.

APP_NAME=secondbrain-voice-gateway
ENVIRONMENT=production
HOST=0.0.0.0
PORT=8000
GATEWAY_PORT=8000
LOG_LEVEL=INFO
REQUEST_TIMEOUT_SECONDS=8
DEBUG_ENDPOINTS_ENABLED=false
TRUST_X_FORWARDED_FOR=false
REVERSE_PROXY_IP_ALLOWLIST=

ALEXA_APPLICATION_IDS=amzn1.ask.skill.your-skill-id
ALEXA_VERIFY_SIGNATURE=true
ALEXA_SIGNATURE_TOLERANCE_SECONDS=150
ALEXA_CERT_CACHE_TTL_SECONDS=3600
ALEXA_ENABLE_REPROMPT=true

SECOND_BRAIN_ENABLED=true
SECOND_BRAIN_BASE_URL=http://secondbrain:8000
SECOND_BRAIN_QUERY_PATH=/query
SECOND_BRAIN_HEALTH_PATH=/health
SECOND_BRAIN_QUERY_FIELD_NAME=question
SECOND_BRAIN_BEARER_TOKEN=
SECOND_BRAIN_TOKEN_FILE=./secrets/secondbrain_token.txt

HOME_ASSISTANT_ENABLED=true
HOME_ASSISTANT_BASE_URL=http://homeassistant:8123
HOME_ASSISTANT_TOKEN=
HOME_ASSISTANT_TOKEN_FILE=./secrets/home_assistant_token.txt
HOME_ASSISTANT_ALIAS_CONFIG_PATH=./configs/home_assistant_aliases.yml

DOCKER_ENABLED=true
DOCKER_BASE_URL=http://docker-proxy:2375
DOCKER_MONITORS_CONFIG_PATH=./configs/docker_services.yml
DOCKER_INCLUDE_LOG_HINTS=true
DOCKER_LOGS_TAIL=50

TROUBLESHOOTING_CONFIG_PATH=./configs/troubleshooting_knowledge.yml

AI_ENABLED=false
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=
AI_API_KEY_FILE=./secrets/ai_api_key.txt
AI_MODEL=gpt-4o-mini
AI_TIMEOUT_SECONDS=10
